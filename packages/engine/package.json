{
  "name": "@lucid-2d/engine",
  "version": "0.3.1",
  "description": "Lucid game engine — app lifecycle, scene routing, platform adapters (Web/Wx/Tt)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    }
  },
  "files": [
    "dist/",
    "src/"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@lucid-2d/core": "workspace:*"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^0.1.97",
    "@types/node": "^25.5.0",
    "jsdom": "^29.0.0",
    "vitest": "^3.1.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucid-2d/lucid.git",
    "directory": "packages/engine"
  }
}
